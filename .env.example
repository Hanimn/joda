# joda — example environment. Copy to .env and adjust. All vars are optional;
# defaults (see backend/config.py) give a working local/dev setup.

# --- Queue ---
JODA_REDIS_URL=redis://localhost:6379/0

# --- Demucs ---
# Leave blank for CPU/auto; set cuda or mps for GPU workers (big speedup).
JODA_DEVICE=
JODA_SEPARATION_TIMEOUT=900

# --- Storage: "local" (disk) or "s3" (S3/R2/GCS/minio) ---
JODA_STORAGE_BACKEND=local
# When JODA_STORAGE_BACKEND=s3:
JODA_S3_BUCKET=joda
JODA_S3_ENDPOINT_URL=          # e.g. http://localhost:9000 for minio; blank = AWS
JODA_S3_PUBLIC_ENDPOINT_URL=   # browser-reachable endpoint for presigned URLs
JODA_S3_REGION=us-east-1
JODA_S3_ACCESS_KEY=            # blank = use standard AWS creds/role
JODA_S3_SECRET_KEY=
JODA_S3_PRESIGN_TTL=3600

# --- Uploads / retention ---
JODA_MAX_UPLOAD_BYTES=104857600   # 100 MB
JODA_ARTIFACT_TTL=21600           # 6h; 0 disables the sweeper

# --- Result cache (dedupe identical uploads) ---
JODA_CACHE_ENABLED=true
JODA_CACHE_TTL=604800             # 7 days to remember a content-hash -> result

# --- Rate limiting (per client IP, fixed 1-min window) ---
JODA_RATE_LIMIT_PER_MIN=10        # 0 disables

# --- Observability ---
JODA_SENTRY_DSN=               # blank = disabled
JODA_ENVIRONMENT=development
JODA_LOG_LEVEL=INFO
