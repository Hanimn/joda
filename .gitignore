sample/

# Local Claude Code settings / permissions
.claude/

# Brand kit — the full Claude Design output. The runtime assets the app and
# README actually use were copied into frontend/assets/ and assets/github/,
# which stay tracked; this source kit itself is not published.
Joda-Branding/
